# Application
APP_NAME=VORTYX
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=false
API_PREFIX=/api

# Security
JWT_SECRET_KEY=replace_with_at_least_32_characters_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=480
REFRESH_TOKEN_EXP_MINUTES=10080
RFID_CREDENTIALS_KEY=replace_with_fernet_key_base64_32bytes

# Database
DATABASE_URL=postgresql://vortex_user:change_me@db:5432/vortex
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CHANNEL_ALERTS=vortyx.alerts
REDIS_CHANNEL_TASKS=vortyx.tasks

# Proxmox
PROXMOX_NODES=pve1:10.10.0.11,pve2:10.10.0.12
PROXMOX_USERNAME=api-user@pve
PROXMOX_PASSWORD=replace_me
PROXMOX_VERIFY_SSL=false

# phpIPAM
PHPIPAM_BASE_URL=https://phpipam.internal
PHPIPAM_APP_ID=vortyx
PHPIPAM_TOKEN=replace_me
PHPIPAM_VM_SUBNET_ID=100
PHPIPAM_VDI_SUBNET_ID=200

# Guacamole
GUAC_BASE_URL=https://guac.internal
GUAC_USERNAME=guac_api_user
GUAC_PASSWORD=replace_me

# AWX
AWX_BASE_URL=https://awx.internal
AWX_TOKEN=replace_me

# HTTP/CORS
CORS_ORIGINS=http://localhost:3000,https://vortyx.internal
ALLOWED_HOSTS=localhost,127.0.0.1,vortyx.internal

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
