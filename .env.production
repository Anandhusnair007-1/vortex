# ====== Application Configuration ======
APP_NAME=VORTYX
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=false

# ====== Network Configuration ======
# Get your server IP and domain name and replace below
SERVER_IP=10.0.0.100
SERVER_DOMAIN=vortex.internal

# ====== Database Configuration ======
POSTGRES_DB=vortex
POSTGRES_USER=vortex_user
# ⚠️ GENERATE A STRONG PASSWORD: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ====== Redis Configuration ======
REDIS_URL=redis://redis:6379/0

# ====== JWT Configuration ======
# ⚠️ GENERATE A NEW SECRET: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_32_CHARACTERS_HEX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=480
REFRESH_TOKEN_EXP_MINUTES=10080

# ====== RFID Configuration ======
# ⚠️ GENERATE ENCRYPTION KEY: python -c "import secrets; import base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
RFID_CREDENTIALS_KEY=CHANGE_ME_TO_FERNET_BASE64_KEY

# ====== API URLs for Frontend ======
# Production HTTPS URLs
REACT_APP_API_URL=https://${SERVER_DOMAIN}/api
REACT_APP_WS_URL=wss://${SERVER_DOMAIN}/api/ws

# ====== CORS Configuration ======
# Allow remote clients on your LAN to access the API
CORS_ORIGINS=https://${SERVER_DOMAIN},https://${SERVER_IP},http://localhost:3000
ALLOWED_HOSTS=${SERVER_DOMAIN},${SERVER_IP},localhost,127.0.0.1

# ====== Proxmox Configuration ======
PROXMOX_NODES=pve1:10.10.0.11,pve2:10.10.0.12
PROXMOX_USERNAME=api-user@pve
# ⚠️ Use strong password
PROXMOX_PASSWORD=change_me
# Enable SSL verification for secure Proxmox connections
PROXMOX_VERIFY_SSL=true

# ====== phpIPAM Configuration ======
PHPIPAM_BASE_URL=https://phpipam.internal
PHPIPAM_APP_ID=vortyx
PHPIPAM_TOKEN=change_me
PHPIPAM_VM_SUBNET_ID=100
PHPIPAM_VDI_SUBNET_ID=200

# ====== Guacamole Configuration ======
GUAC_BASE_URL=https://guac.internal
GUAC_USERNAME=guac_api_user
GUAC_PASSWORD=change_me

# ====== AWX Configuration ======
AWX_BASE_URL=https://awx.internal
AWX_TOKEN=change_me

# ====== Observium Configuration ======
OBSERVIUM_API_URL=https://observium.internal/api
OBSERVIUM_API_TOKEN=change_me

# ====== Logging ======
LOG_LEVEL=INFO
LOG_JSON=true

# ====== Security ======
# Disable internal auth bypass in production
INTERNAL_AUTH_BYPASS=false

# ====== SSL Certificate Paths ======
# Place your SSL certificate files in ./certs/
# cert.pem - public certificate
# key.pem - private key
