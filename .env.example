# ====== Database Configuration ======
POSTGRES_DB=vortex
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
DB_PORT=5432

# ====== Redis Configuration ======
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ====== JWT Configuration ======
JWT_SECRET_KEY=your-super-secret-key-change-in-production-12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=7

# ====== API Configuration ======
BACKEND_PORT=8000
FRONTEND_PORT=3000
DEBUG=false

# ====== React Configuration ======
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# ====== Proxmox Configuration ======
PROXMOX_NODES=node1:192.168.1.10,node2:192.168.1.11,node3:192.168.1.12
PROXMOX_USERNAME=root@pam
PROXMOX_PASSWORD=proxmox_password
PROXMOX_VERIFY_SSL=false

# ====== Observium Configuration ======
OBSERVIUM_API_URL=http://observium.local/api
OBSERVIUM_API_TOKEN=your_observium_token

# ====== AWX Configuration ======
AWX_API_URL=http://awx.local/api/v2
AWX_USERNAME=admin
AWX_PASSWORD=awx_password
AWX_VERIFY_SSL=false

# ====== RFID Configuration ======
RFID_DEVICE_TIMEOUT=30
RFID_SESSION_CACHE_TTL=3600

# ====== Email Configuration (for alerts) ======
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_FROM=alerts@vortex.internal

# ====== Logging Configuration ======
LOG_LEVEL=INFO
LOG_FILE=/var/log/vortex/backend.log

# ====== Security ======
ALLOWED_HOSTS=localhost,127.0.0.1,vortex.internal
CORS_ORIGINS=http://localhost:3000,https://vortex.internal

# ====== Feature Flags ======
ENABLE_RFID_MODULE=true
ENABLE_ALERT_SYSTEM=true
ENABLE_VM_SYNC=true
ENABLE_REPORTS=true
